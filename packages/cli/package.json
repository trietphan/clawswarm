{
  "name": "@clawswarm/cli",
  "version": "0.1.0-alpha",
  "description": "CLI for ClawSwarm — init projects, start the bridge, and inspect agent status",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawswarm": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clawswarm/bridge": "0.1.0-alpha",
    "@clawswarm/core": "0.1.0-alpha",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "enquirer": "^2.4.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "multi-agent",
    "orchestration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trietphan/clawswarm.git",
    "directory": "packages/cli"
  }
}
