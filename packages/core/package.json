{
  "name": "@clawswarm/core",
  "version": "0.1.0",
  "description": "Core agent framework for ClawSwarm",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js",
      "default": "./dist/agent.js"
    },
    "./goal": {
      "types": "./dist/goal.d.ts",
      "import": "./dist/goal.js",
      "default": "./dist/goal.js"
    },
    "./task": {
      "types": "./dist/task.d.ts",
      "import": "./dist/task.js",
      "default": "./dist/task.js"
    },
    "./chief": {
      "types": "./dist/chief.d.ts",
      "import": "./dist/chief.js",
      "default": "./dist/chief.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "eventemitter3": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trietphan/clawswarm.git",
    "directory": "packages/core"
  }
}
