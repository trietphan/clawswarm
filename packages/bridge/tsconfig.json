{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "paths": {
      "@clawswarm/core": ["../core/src/index.ts"],
      "@clawswarm/core/*": ["../core/src/*.ts"]
    }
  },
  "references": [
    { "path": "../core" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
