# ClawSwarm — Environment Variables
# Copy this file to .env and fill in your API keys.
# You only need keys for the providers your agents use.

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# OpenAI (GPT models)
OPENAI_API_KEY=

# Google AI (Gemini models)
GOOGLE_AI_API_KEY=

# Bridge server (optional — used by bridge-realtime example)
BRIDGE_PORT=8080
BRIDGE_AUTH_TOKEN=

# OSS Dashboard Bridge (optional — report clawswarm run events to clawswarm.app)
# Set CLAWSWARM_API_KEY to activate reporting. Get your key at https://clawswarm.app/settings/api-keys
CLAWSWARM_API_KEY=
CLAWSWARM_DASHBOARD_URL=https://clawswarm.app
